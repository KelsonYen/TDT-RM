{
  "notes": "Production public endpoints for provider CSV generation. Live sources are official TWSE/TAIFEX public OpenAPI/report endpoints and are attempted by fallback_order. Local price fallbacks are disabled templates only; production runs should not use cli_price_fallback_csv.",
  "sources": [
    {
      "source_id": "twse_fmtqik_price",
      "source_name": "TWSE monthly market summary (FMTQIK)",
      "provider_category": "price",
      "adapter": "twse_fmtqik_price",
      "endpoint_url_template": "https://www.twse.com.tw/rwd/en/exchangeReport/FMTQIK?date={yyyymmdd}&response=json",
      "request_parameters": {
        "date": "{yyyymmdd}",
        "response": "json"
      },
      "response_type": "json",
      "freshness_rules": {
        "max_lag_days": 3
      },
      "lookback_months": 4,
      "min_bars": 61,
      "notes": "Official TWSE report for daily total-market trading value, TAIEX close, and daily change. Four monthly pulls provide enough history to derive MA5/MA20/MA60, turnover MA20, 5D/60D returns, previous MA60, and below-MA20 streak.",
      "enabled": true,
      "fallback_order": 10,
      "source_type": "twse_official_json"
    },
    {
      "source_id": "twse_taiex_price_legacy",
      "source_name": "TWSE TAIEX monthly OHLC (MI_5MINS_HIST)",
