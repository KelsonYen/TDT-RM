      "endpoint_url_template": "https://www.twse.com.tw/rwd/en/TAIEX/MI_5MINS_HIST?date={yyyymmdd}&response=json",
      "request_parameters": {
        "date": "{yyyymmdd}",
        "response": "json"
      },
      "response_type": "json",
      "rows_path": "data",
      "freshness_rules": {
        "max_lag_days": 3
      },
      "min_bars": 61,
      "notes": "Official TWSE index OHLC endpoint retained as a lower-priority live fallback when 61+ bars are available for strict production price features.",
      "enabled": true,
      "fallback_order": 20,
      "source_type": "twse_json"
    },
    {
      "source_id": "taiwan_index_plus_price",
      "source_name": "Taiwan Index Plus official index data",
